{
  "id": "doc_page",
  "label": "Doc Page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "e.g. Onboarding Guide"
        }
      },
      "category": {
        "type": "Select",
        "config": {
          "label": "Category",
          "options": ["about", "policies", "trainings", "roles"],
          "default_value": "trainings"
        }
      },
      "breadcrumb_label": {
        "type": "Text",
        "config": {
          "label": "Breadcrumb Label",
          "placeholder": "Short label for breadcrumb trail"
        }
      },
      "reading_time": {
        "type": "Number",
        "config": {
          "label": "Reading Time (minutes)"
        }
      },
      "badge_label": {
        "type": "Text",
        "config": {
          "label": "Badge Label",
          "placeholder": "e.g. Popular, Required, New"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "labels": {},
          "choices": {
            "rich_text": {
              "type": "SharedSlice"
            },
            "callout_block": {
              "type": "SharedSlice"
            },
            "step_list": {
              "type": "SharedSlice"
            },
            "card_grid": {
              "type": "SharedSlice"
            },
            "contact_table": {
              "type": "SharedSlice"
            },
            "faq_accordion": {
              "type": "SharedSlice"
            }
          }
        }
      }
    }
  }
}
